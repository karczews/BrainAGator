    <!-- Game Descriptions for TTS -->
    <string name="desc_shape_match">W tej grze musisz znaleźć konkretny kształt w danym kolorze. Przyjrzyj się siatce pokolorowanych kształtów i dotknij tego, który pasuje do instrukcji!</string>
    <string name="desc_number_order">W tej grze musisz ułożyć liczby od najmniejszej do największej. Zacznij od najmniejszej liczby i idź coraz wyżej!</string>
    <string name="desc_color_match">W tej grze musisz znaleźć i dopasować te same kolory razem. Szukaj kolorów, które wyglądają dokładnie tak samo!</string>
    <string name="desc_size_order">W tej grze musisz ułożyć obiekty od najmniejszego do największego. Zacznij od malutkich, a skończ na ogromnych!</string>
    <string name="desc_pattern">W tej grze musisz uzupełnić wzór, wybierając odpowiedni kształt. Sprawdź, jaki kształt pasuje jako następny!</string>
    <string name="desc_odd_one_out">W tej grze musisz znaleźć jeden obiekt, który nie pasuje do pozostałych. Szukaj tego, który jest inny!</string>
    <string name="desc_spot_difference">W tej grze musisz znaleźć różnice między dwoma obrazkami. Przyjrzyj się dokładnie obu obrazkom i znajdź co się różni!</string>

